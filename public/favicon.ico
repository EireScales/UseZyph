<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
  <defs>
    <radialGradient id="orb" cx="35%" cy="30%" r="70%">
      <stop offset="0%" stop-color="#c084fc" stop-opacity="0.9"/>
      <stop offset="40%" stop-color="#7c3aed" stop-opacity="0.85"/>
      <stop offset="100%" stop-color="#e8837a" stop-opacity="0.8"/>
    </radialGradient>
    <radialGradient id="inner" cx="30%" cy="25%" r="60%">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
    </radialGradient>
    <filter id="blur">
      <feGaussianBlur stdDeviation="0.5"/>
    </filter>
    <clipPath id="shape">
      <path d="M16 2 C22 2 28 6 29 12 C30 16 29 20 26 23 C23 27 19 30 15 30 C10 30 5 27 3 22 C1 17 2 11 6 7 C9 4 13 2 16 2 Z"/>
    </clipPath>
  </defs>

  <!-- Base shape - liquid glass blob -->
  <path d="M16 2 C22 2 28 6 29 12 C30 16 29 20 26 23 C23 27 19 30 15 30 C10 30 5 27 3 22 C1 17 2 11 6 7 C9 4 13 2 16 2 Z"
    fill="url(#orb)"/>

  <!-- Glass inner highlight -->
  <path d="M16 2 C22 2 28 6 29 12 C30 16 29 20 26 23 C23 27 19 30 15 30 C10 30 5 27 3 22 C1 17 2 11 6 7 C9 4 13 2 16 2 Z"
    fill="url(#inner)" clip-path="url(#shape)"/>

  <!-- Top gloss reflection -->
  <ellipse cx="13" cy="8" rx="5" ry="3" fill="white" opacity="0.25" transform="rotate(-15 13 8)"/>

  <!-- Z letter -->
  <text x="16" y="21" font-family="SF Pro Display, -apple-system, sans-serif" font-size="14" font-weight="700"
    fill="white" opacity="0.95" text-anchor="middle" letter-spacing="-0.5">Z</text>
</svg>
